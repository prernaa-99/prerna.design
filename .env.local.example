# Copy this file to .env.local and fill in your IDs.
# Analytics only loads when its ID is present, so leaving one blank disables it.

# Google Analytics 4 — get from https://analytics.google.com (Admin → Data Streams)
# Looks like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity — get from https://clarity.microsoft.com (Settings → Overview)
# Looks like: abcd1234ef
NEXT_PUBLIC_CLARITY_ID=
